# G1_Hybrid_Graduation 运行环境变量模板。
#
# 可以把这些变量写入本机 shell profile、CI secret，或复制成自己的本地 env 文件。
# 不要把机器相关的绝对路径提交到 Git。
#
# 如果所有模块都安装在当前激活的环境里，保持 python 即可。

G1_MJLAB_PYTHON=python
G1_GVHMR_PYTHON=python
G1_RETARGET_PYTHON=python
G1_29DOF_PYTHON=python

# 可选本地资产目录。模型权重和人体模型通常体积大且有许可限制，所以不提交到仓库。
G1_GVHMR_CHECKPOINT_DIR=motion_pipeline/backends/gvhmr/inputs/checkpoints
G1_SMPL_MODEL_DIR=motion_pipeline/backends/g1_retarget/smpl_retarget/smpl_model/smpl
